{
  "id": "translate-dnd5e-sdr2-es",
  "title": "D&D 5e 한국어 번역 (시스템 UI + SRD 2024)",
  "description": "Foundry VTT의 dnd5e 시스템 한국어 번역본. 시스템 UI(능력치·시트·상태·주문 등) 전체 한국어화 + D&D 2024 SRD 주제집(주문·몬스터·장비·클래스·기원·규칙·표) Babele 번역 + D&D 2024 스타일 일지/스탯블록 + 한국어 폰트. 원본: LuckyFrico(이탈리아어)·foundryvtt-sinregistrar(스페인어).",
  "version": "2.0.6",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "languages": [
    {
      "lang": "ko",
      "name": "한국어",
      "path": "lang/ko.json"
    }
  ],
  "relationships": {
    "systems": [
      {
        "id": "dnd5e",
        "manifest": "https://raw.githubusercontent.com/foundryvtt/dnd5e/master/system.json",
        "compatibility": {
          "minimum": "5.2.1",
          "verified": "5.3.3"
        },
        "type": "system"
      }
    ],
    "requires": [
      {
        "id": "babele",
        "type": "module",
        "manifest": "https://gitlab.com/riccisi/foundryvtt-babele/raw/master/module/module.json",
        "compatibility": {
          "minimum": "2.7.5",
          "verified": "2.7.5"
        }
      }
    ],
    "recommends": [
      {
        "id": "dnd-monster-manual",
        "type": "module",
        "manifest": "https://foundryvtt.com/packages/dnd-monster-manual",
        "compatibility": {
          "minimum": "1.3.0",
          "verified": "1.3.0"
        },
        "reason": "Optional but recommended to resolve external embeds in dnd5e.content24."
      }
    ]
  },
  "esmodules": [
    "scripts/converters.js",
    "scripts/babele-register.js",
    "main.js"
  ],
  "styles": [
    "styles/dnd-ita.css"
  ],
  "packs": [
    {
      "name": "macro",
      "label": "미터법 단위 변환",
      "path": "packs/macro",
      "type": "Macro",
      "system": "dnd5e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      },
      "flags": {}
    }
  ],
  "packFolders": [
    {
      "name": "D&D 5e 한국어 번역",
      "color": "#39b157",
      "sorting": "m",
      "packs": [
        "macro"
      ],
      "folders": []
    }
  ],
  "authors": [
    {
      "name": "LuckyFrico (이탈리아어 원본)"
    },
    {
      "name": "foundryvtt-sinregistrar (스페인어 베이스)"
    },
    {
      "name": "sepi-toolbox (한국어 번역)"
    }
  ],
  "url": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko",
  "manifest": "https://raw.githubusercontent.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/main/module.json",
  "download": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/archive/refs/heads/main.zip",
  "bugs": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/issues",
  "readme": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/blob/main/README.md",
  "changelog": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/commits/main",
  "license": "https://github.com/sepi-toolbox/translate-dnd5e-sdr2-es-ko/blob/main/LICENSE"
}
